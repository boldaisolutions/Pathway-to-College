# ---- Supabase ----------------------------------------------------------------
# Settings → API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://phvunxdokxenebjolazz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key            # safe in the browser (protected by RLS)

# Server-only secrets — NEVER commit, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key               # bypasses RLS; used for seeding/admin
ANTHROPIC_API_KEY=your-anthropic-api-key                      # for AI routes (Coach, idea generation)

# ---- App ---------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Copy this file to `.env.local` and fill in real values.
# Make sure `.env.local` is listed in .gitignore.
